{
  "id": "render.alert",
  "category": "render",
  "categoryLabel": "Page Builder",
  "icon": "layout-text-window",
  "color": "var(--sol-violet)",
  "label": "Alert Box",
  "desc": "Append a hidden Bootstrap alert (show via display.text or form errors).",
  "version": "1.0.0",
  "params": [
    {
      "name": "id",
      "label": "Element ID",
      "type": "text",
      "placeholder": "login-alert"
    },
    {
      "name": "type",
      "label": "Type",
      "type": "select",
      "options": [
        "danger",
        "warning",
        "info",
        "success"
      ],
      "default": "danger"
    },
    {
      "name": "text",
      "label": "Initial text (leave blank to hide)",
      "type": "text",
      "default": ""
    }
  ]
}
