{
  "id": "render.button",
  "category": "render",
  "categoryLabel": "Page Builder",
  "icon": "layout-text-window",
  "color": "var(--sol-violet)",
  "label": "Button",
  "desc": "Append a button that navigates to a room (runs onExit first).",
  "version": "1.0.0",
  "params": [
    {
      "name": "label",
      "label": "Label",
      "type": "text",
      "placeholder": "Sign In"
    },
    {
      "name": "target",
      "label": "Room",
      "type": "room",
      "placeholder": "auth-check"
    },
    {
      "name": "variant",
      "label": "Style",
      "type": "select",
      "options": [
        "primary",
        "secondary",
        "outline-secondary",
        "outline-info",
        "danger",
        "success"
      ],
      "default": "primary"
    },
    {
      "name": "full",
      "label": "Full width",
      "type": "boolean",
      "default": true
    }
  ]
}
