{
  "id": "media.askImageUpload",
  "category": "media",
  "categoryLabel": "Media & Upload",
  "icon": "film",
  "color": "var(--sol-magenta)",
  "label": "Ask for Image Upload",
  "desc": "Open file picker for an image. Preview before accepting.",
  "version": "1.0.0",
  "params": [
    {
      "name": "label",
      "label": "Prompt label",
      "type": "text",
      "placeholder": "Upload an image"
    },
    {
      "name": "accept",
      "label": "Accept",
      "type": "text",
      "placeholder": "image/*",
      "default": "image/*"
    },
    {
      "name": "preview",
      "label": "Show preview",
      "type": "boolean",
      "default": true
    },
    {
      "name": "into",
      "label": "Store in var",
      "type": "text",
      "placeholder": "uploadedImage"
    }
  ]
}
