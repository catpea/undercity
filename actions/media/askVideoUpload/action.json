{
  "id": "media.askVideoUpload",
  "category": "media",
  "categoryLabel": "Media & Upload",
  "icon": "film",
  "color": "var(--sol-magenta)",
  "label": "Ask for Video Upload",
  "desc": "Open file picker for a video. Optionally extract a preview thumbnail frame.",
  "version": "1.0.0",
  "params": [
    {
      "name": "label",
      "label": "Prompt label",
      "type": "text",
      "placeholder": "Select a video"
    },
    {
      "name": "accept",
      "label": "Accept types",
      "type": "text",
      "placeholder": "video/*",
      "default": "video/*"
    },
    {
      "name": "thumbnailPrompt",
      "label": "Thumbnail prompt",
      "type": "text",
      "placeholder": "Select a frame as thumbnail",
      "default": "Select a frame that serves as a good preview thumbnail"
    },
    {
      "name": "extractThumb",
      "label": "Extract thumbnail",
      "type": "boolean",
      "default": true
    },
    {
      "name": "into",
      "label": "Store in var",
      "type": "text",
      "placeholder": "uploadedVideo"
    }
  ]
}
