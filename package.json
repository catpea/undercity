{
  "name": "undercity",
  "version": "1.0.8",
  "description": "Visual flow IDE — MUD-style logic graph builder with Bootstrap code generation",
  "type": "module",
  "main": "server.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "node packages/process-manager/pm.js start network-services/ecosystem.json",
    "dev": "NODE_ENV=development node packages/process-manager/pm.js start network-services/ecosystem.json",
    "logs": "node packages/process-manager/pm.js logs",
    "save": "git add .; git commit -m 'Updated Release'; npm version patch; npm publish; git push --follow-tags;"
  },
  "author": "catpea (https://github.com/catpea)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/catpea/undercity.git"
  },
  "bugs": {
    "url": "https://github.com/catpea/undercity/issues"
  },
  "homepage": "https://github.com/catpea/undercity",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/catpea"
  }
}
