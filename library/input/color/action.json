{
  "id":      "input.color",
  "icon":    "palette",
  "color":   "var(--sol-blue)",
  "label":   "Ask For Color",
  "desc":    "Render a color swatch picker. The hex value is shown beside the swatch so the user always knows what they picked. Two-way bound to an inventory key.",
  "version": "1.0.0",
  "params": [
    { "name": "key",     "label": "Inventory key", "type": "text", "placeholder": "brandColor" },
    { "name": "label",   "label": "Label",         "type": "text", "placeholder": "Brand Color" },
    { "name": "default", "label": "Default color", "type": "text", "placeholder": "#268bd2", "default": "#268bd2" },
    { "name": "helpText",        "label": "Help text",        "type": "textarea", "placeholder": "Explain what belongs in this field.", "default": "" },
    { "name": "size",            "label": "Size",             "type": "select",   "options": ["","sm","lg"], "default": "" },
    { "name": "validFeedback",   "label": "Valid feedback",   "type": "text",     "placeholder": "Looks good!", "default": "" },
    { "name": "invalidFeedback", "label": "Invalid feedback", "type": "text",     "placeholder": "Please choose a valid color.", "default": "" }
  ]
}
