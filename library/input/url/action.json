{
  "id":      "input.url",
  "icon":    "link-45deg",
  "color":   "var(--sol-blue)",
  "label":   "Ask For Web Address",
  "desc":    "Render a URL field. The browser validates the format before submission. Two-way bound to an inventory key.",
  "version": "1.0.0",
  "params": [
    { "name": "key",         "label": "Inventory key", "type": "text",    "placeholder": "website" },
    { "name": "label",       "label": "Label",         "type": "text",    "placeholder": "Website" },
    { "name": "placeholder", "label": "Placeholder",   "type": "text",    "placeholder": "https://example.com" },
    { "name": "required",    "label": "Required",      "type": "boolean", "default": false },
    { "name": "helpText",        "label": "Help text",        "type": "textarea", "placeholder": "Explain what belongs in this field.", "default": "" },
    { "name": "size",            "label": "Size",             "type": "select",   "options": ["","sm","lg"], "default": "" },
    { "name": "validFeedback",   "label": "Valid feedback",   "type": "text",     "placeholder": "Looks good!", "default": "" },
    { "name": "invalidFeedback", "label": "Invalid feedback", "type": "text",     "placeholder": "Please provide a valid URL.", "default": "" }
  ]
}
